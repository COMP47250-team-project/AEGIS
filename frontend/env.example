# frontend/.env.example
#
# Copy this file to .env and fill in the values for local development.
# NEVER commit .env to git (it's already in .gitignore).
#
# In Vite, environment variables must start with VITE_ to be accessible
# in the browser-side code (via import.meta.env.VITE_...).

# The URL of the FastAPI backend.
# During local development this is http://localhost:8000
VITE_API_URL=http://localhost:8000
