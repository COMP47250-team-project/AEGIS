# AEGIS — Anti-Cheat Exam Portal


#  Database
#DATABASE_URL=postgresql+asyncpg://aegis:aegis_dev_pw@localhost:5432/aegis
#DATABASE_URL_SYNC=postgresql://aegis:aegis_dev_pw@localhost:5432/aegis
DATABASE_URL = postgresql://postgres:admin123@localhost:5432/infiniteLoops
DATABASE_URL_SYNC=postgresql://postgres:admin123@localhost:5432/infiniteLoops


#  JWT
JWT_SECRET=change_me_to_a_random_64_char_string
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=480

#  Azure identity (managed identity / service principal client ID)
AZURE_CLIENT_ID=

#  Azure Service Bus
AZURE_SERVICE_BUS_CONNECTION_STRING=Endpoint=sb://...
AZURE_SERVICE_BUS_QUEUE_NAME=telemetry-events

#  Azure Blob Storage
AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;...
AZURE_STORAGE_CONTAINER_NAME=event-tape

#  App
APP_ENV=development
BACKEND_CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]
LOG_LEVEL=DEBUG

#  Frontend (Vite public vars — prefix with VITE_)
VITE_API_BASE_URL=http://localhost:8000
VITE_WS_BASE_URL=ws://localhost:8000
